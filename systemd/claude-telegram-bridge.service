[Unit]
Description=Claude Telegram Bridge
After=network-online.target
Wants=network-online.target
ConditionPathExists=%h/dev/telegram-agent-bridges/bridges/claude/.env

[Service]
Type=simple
WorkingDirectory=%h/dev/telegram-agent-bridges/bridges/claude
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/dev/telegram-agent-bridges/bridges/claude/run-bridge.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
