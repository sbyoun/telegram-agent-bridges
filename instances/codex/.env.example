BRIDGE_PROVIDER=codex
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
CODEX_WORKDIR=/home/ubuntu
CODEX_BIN=/home/ubuntu/.npm-global/bin/codex
# CODEX_MODEL=
CODEX_EXTRA_ARGS=
# Hide sessions whose cwd is under these paths from /sessions (comma-separated).
# Defaults to /home/ubuntu/loop-engine when unset; set to empty to disable.
# CODEX_EXCLUDE_CWDS=/home/ubuntu/loop-engine
TELEGRAM_PLAIN_TEXT_AS_RUN=1
TELEGRAM_POLL_TIMEOUT=20
