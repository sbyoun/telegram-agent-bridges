# Antigravity (agy) instance — successor to the deprecated Gemini CLI bridge.
# Copy to .env and set TELEGRAM_BOT_TOKEN before enabling.
BRIDGE_PROVIDER=antigravity
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_ALLOWED_CHAT_IDS=123456789
ANTIGRAVITY_WORKDIR=/home/ubuntu
ANTIGRAVITY_BIN=/home/ubuntu/.local/bin/agy
# Model is configured inside agy's own settings.json (no --model flag), so
# ANTIGRAVITY_MODEL is ignored by the provider.
# ANTIGRAVITY_MODEL=
ANTIGRAVITY_EXTRA_ARGS=
TELEGRAM_PLAIN_TEXT_AS_RUN=1
TELEGRAM_POLL_TIMEOUT=20
