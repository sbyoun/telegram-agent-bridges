# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Comma-separated chat ids allowed to talk to the relay (your own account/channel)
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Where outgoing notify/ask messages are sent.
# Optional: defaults to the single allowed chat id above.
# TELEGRAM_TARGET_CHAT_ID=123456789

# Long-poll timeout in seconds (Telegram getUpdates)
# TELEGRAM_POLL_TIMEOUT=25

# Streamable-HTTP MCP endpoint the agents connect to
# MCP_HOST=127.0.0.1
# MCP_PORT=8765
